# Edge Agent 환경변수 예시
# 복사 후 .env로 이름 변경하여 사용

# 지점/기계 식별
SITE_ID=site-A
MACHINE_ID=cnc-001

# FastAPI
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_ANOMALY_EVENTS=anomaly-events
KAFKA_TOPIC_SENSOR_TELEMETRY=sensor-telemetry
KAFKA_TELEMETRY_INTERVAL_SEC=30

# 모델
MODEL_DIR=./models
MODEL_VERSION=v1.0.0
# 임계값 오버라이드 (설정 시 info.json의 3sigma 임계값 대신 사용)
# MODEL_THRESHOLD_OVERRIDE_COOLANT=0.02
# MODEL_THRESHOLD_OVERRIDE_HYDRAULICS=0.035
# MODEL_THRESHOLD_OVERRIDE_PROBE=0.03

# 데이터 수집
DATA_REPLAY_MODE=true
DATA_REPLAY_CSV_DIR=../../real_op
DATA_REPLAY_SPEED_FACTOR=10.0
DATA_RESAMPLE_INTERVAL=1.0
DATA_WINDOW_SIZE=30
DATA_PROCESSED_DATA_DIR=../../anomaly_detection/processed_data_v2
