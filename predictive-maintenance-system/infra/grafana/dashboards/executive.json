      "targets": [{ "rawSql": "SELECT subsystem AS metric, COUNT(*) AS value FROM anomaly_events WHERE is_resolved=false GROUP BY subsystem", "format": "table", "refId": "A" }]
    },
    {
      "type": "piechart",
      "title": "기계별 이상 분포",
