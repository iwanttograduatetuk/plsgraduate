      "options": { "tooltip": { "mode": "multi" } },
      "targets": [{ "rawSql": "SELECT date_trunc('minute', detected_at) AS time, COUNT(*) AS value FROM anomaly_events WHERE detected_at >= NOW() - INTERVAL '1 hour' GROUP BY 1 ORDER BY 1", "format": "time_series", "refId": "A" }]
    }
