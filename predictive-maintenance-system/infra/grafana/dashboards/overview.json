{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0" },
    { "type": "datasource", "id": "postgres", "name": "PostgreSQL", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "CNC 다중 거점 예지보전 — 전체 지점 현황 Overview",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "총 이상 감지 (미처리)",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "mappings": []
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS value FROM anomaly_events WHERE is_resolved = false",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "긴급(CRITICAL) 이상",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS value FROM anomaly_events WHERE severity='CRITICAL' AND is_resolved=false",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "전체 기계 대수",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS value FROM machines",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "최근 이상 이벤트 (실시간)",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 4 },
      "id": 4,
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "감지시각", "desc": true }]
      },
      "targets": [
        {
          "rawSql": "SELECT detected_at AS \"감지시각\", site_id AS \"지점\", machine_id AS \"기계\", subsystem AS \"서브시스템\", ROUND(anomaly_score::numeric, 3) AS \"이상점수\", severity AS \"심각도\", is_resolved AS \"처리완료\" FROM anomaly_events ORDER BY detected_at DESC LIMIT 50",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Hydraulics 재구성 오차 시계열 (site-A / cnc-001)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 5,
      "datasource": { "type": "influxdb", "uid": "InfluxDB" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "threshold" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [5, 5] } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "query": "from(bucket: \"sensor-scores\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"subsystem_scores\")\n  |> filter(fn: (r) => r[\"site_id\"] == \"site-A\")\n  |> filter(fn: (r) => r[\"machine_id\"] == \"cnc-001\")\n  |> filter(fn: (r) => r[\"subsystem\"] == \"hydraulics\")\n  |> filter(fn: (r) => r[\"_field\"] == \"reconstruction_error\" or r[\"_field\"] == \"threshold\")\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Coolant / Probe 재구성 오차 시계열",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 6,
      "datasource": { "type": "influxdb", "uid": "InfluxDB" },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "query": "from(bucket: \"sensor-scores\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"subsystem_scores\")\n  |> filter(fn: (r) => r[\"site_id\"] == \"site-A\")\n  |> filter(fn: (r) => r[\"machine_id\"] == \"cnc-001\")\n  |> filter(fn: (r) => r[\"subsystem\"] == \"coolant\" or r[\"subsystem\"] == \"probe\")\n  |> filter(fn: (r) => r[\"_field\"] == \"reconstruction_error\")",
          "refId": "A"
        }
      ]
    },
    {
      "type": "barchart",
      "title": "Root Cause 상위 변수 (최근 이상 이벤트)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "id": 7,
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "options": { "orientation": "horizontal", "xTickLabelRotation": 0 },
      "targets": [
        {
          "rawSql": "SELECT rc->>'variable' AS variable, ROUND((rc->>'score')::numeric, 3) AS score FROM fault_diagnosis_results, jsonb_array_elements(root_causes) rc ORDER BY diagnosed_at DESC, score DESC LIMIT 10",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Fault Diagnosis 결과 이력",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "id": 8,
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [
        {
          "rawSql": "SELECT fdr.diagnosed_at AS \"진단시각\", ae.site_id AS \"지점\", ae.machine_id AS \"기계\", ae.subsystem AS \"서브시스템\", fdr.model_name AS \"모델\", ROUND(fdr.confidence::numeric, 3) AS \"신뢰도\", fdr.root_causes->0->>'variable' AS \"원인1위\" FROM fault_diagnosis_results fdr JOIN anomaly_events ae ON fdr.event_id = ae.event_id ORDER BY fdr.diagnosed_at DESC LIMIT 30",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["CNC", "예지보전", "이상감지"],
  "templating": {
    "list": [
      {
        "name": "monitoring_url",
        "type": "constant",
        "label": "Monitoring API URL",
        "query": "http://localhost:8082",
        "current": { "value": "http://localhost:8082" },
        "hide": 2
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "CNC 예지보전 — 전체 지점 현황",
