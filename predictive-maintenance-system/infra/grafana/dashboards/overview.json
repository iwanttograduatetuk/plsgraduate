      "title": "Fault Diagnosis 결과 이력",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "id": 8,
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [
        {
          "rawSql": "SELECT fdr.diagnosed_at AS \"진단시각\", ae.site_id AS \"지점\", ae.machine_id AS \"기계\", ae.subsystem AS \"서브시스템\", fdr.model_name AS \"모델\", ROUND(fdr.confidence::numeric, 3) AS \"신뢰도\", fdr.root_causes->0->>'variable' AS \"원인1위\" FROM fault_diagnosis_results fdr JOIN anomaly_events ae ON fdr.event_id = ae.event_id ORDER BY fdr.diagnosed_at DESC LIMIT 30",
          "format": "table",
          "refId": "A"
        }
      ]
    },

    {
      "type": "row",
      "title": "기계 제어 패널",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "id": 9,
      "collapsed": false
    },
    {
      "type": "text",
      "title": "CNC 기계 제어",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 31 },
      "id": 10,
      "options": {
        "mode": "html",
        "content": "<iframe src=\"${monitoring_url}/control.html\" width=\"100%\" height=\"100%\" frameborder=\"0\" style=\"min-height:480px; border-radius:4px;\"></iframe>"
      }
    },

    {
      "type": "row",
      "title": "인프라 모니터링",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 45 },
      "id": 11,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "CPU 사용률 (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 46 },
      "id": 12,
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "process_cpu_usage{job=~\"monitoring-api|notification-service\"} * 100",
          "legendFormat": "{{job}} CPU",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM 힙 메모리 사용량",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 46 },
      "id": 13,
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\", job=~\"monitoring-api|notification-service\"}",
          "legendFormat": "{{service}} {{id}}",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_max_bytes{area=\"heap\", job=~\"monitoring-api|notification-service\"}",
          "legendFormat": "{{service}} max",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP 요청 처리율 (rps)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 54 },
      "id": 14,
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"monitoring-api\"}[1m])) by (uri, method)",
          "legendFormat": "{{method}} {{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP 평균 응답 지연 (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 54 },
      "id": 15,
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_sum{job=\"monitoring-api\"}[1m]) / rate(http_server_requests_seconds_count{job=\"monitoring-api\"}[1m]) * 1000",
          "legendFormat": "avg {{uri}}",
          "refId": "A"
        }
      ]
    }
  ]
}
